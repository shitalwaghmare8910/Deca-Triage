# Copy this file to ".env" and fill in real values. Do NOT commit the real .env.
# Microsoft Graph app registration (client-credentials flow).
# Required application permission on the shared mailbox: Mail.ReadWrite

GRAPH_TENANT_ID=your-azure-ad-tenant-id
GRAPH_CLIENT_ID=your-app-registration-client-id
GRAPH_CLIENT_SECRET=your-app-registration-client-secret

# The shared mailbox to monitor (UPN / email address)
SHARED_MAILBOX=alerts@yourdomain.com

# Where to forward detected alerts (Root Orchestrator). Defaults match the
# ServiceNow poller in src/backend/server.py.
ORCHESTRATOR_URL=http://localhost:8080

# Polling behaviour
POLL_INTERVAL=30
REQUEST_TIMEOUT=120
PAGE_SIZE=25

# Optional filters (leave blank to disable)
# Only process emails whose subject contains this keyword:
SUBJECT_FILTER=
# Only process emails from this sender address (substring match):
SENDER_FILTER=

# Mark processed messages as read so they aren't re-processed (recommended)
MARK_AS_READ=true

# ── Mock mode (local demo) ──────────────────────────────────────────────────
# Set EMAIL_LISTENER_MODE=mock to poll the local Mock Outlook service instead
# of real Microsoft 365. In mock mode OAuth is skipped, so the GRAPH_* values
# above are NOT required (only SHARED_MAILBOX is used, as a URL path label).
# Leave unset (or =graph) for the normal, unchanged real-Graph behavior.
# EMAIL_LISTENER_MODE=mock
# When mock mode is on, this defaults to http://localhost:5002/v1.0 already;
# override only if you run the Mock Outlook on a different host/port.
# GRAPH_BASE=http://localhost:5002/v1.0

# ── Forwarding target ─────────────────────────────────────────────────
# FORWARD_MODE=orchestrator (default) -> POST ORCHESTRATOR_URL/process-alert
#   (original behavior; does NOT appear on the backend dashboard).
# FORWARD_MODE=backend -> POST BACKEND_URL/api/ingest-alert so the alert shows
#   on the frontend with a live investigation, like a ServiceNow incident.
# FORWARD_MODE=backend
# BACKEND_URL=http://localhost:5000

# If running behind the DB corporate proxy, also export:
# HTTP_PROXY=http://sp-surf-proxy.intranet.db.com:8080
# HTTPS_PROXY=http://sp-surf-proxy.intranet.db.com:8080
